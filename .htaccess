# ============================================
# Bouddhas.fr — Configuration Hostinger (LiteSpeed/Apache)
# Rewrite des URLs sans extension vers .html
# ============================================

RewriteEngine On

# --- Page produit (SPA) : /produit/SLUG -> produit.html ---
RewriteCond %{REQUEST_URI} !^/produit\.html$
RewriteRule ^produit/(.*)$ /produit.html [L,QSA]

# --- URLs sans extension -> .html si le fichier existe ---
# Ne touche PAS aux fichiers/dossiers existants (css, js, images)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ /$1.html [L]

# --- Page 404 personnalisée ---
ErrorDocument 404 /404.html

# --- Sécurité : interdire l'accès aux fichiers sensibles ---
<FilesMatch "^\.(env|git|htpasswd|htaccess)$">
    Require all denied
</FilesMatch>
<Files ~ "\.(env|py|sh|log)$">
    Require all denied
</Files>

# --- Cache navigateur (perf) ---
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType image/jpg "access plus 30 days"
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/svg+xml "access plus 30 days"
</IfModule>

# --- Compression GZIP (perf) ---
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript image/svg+xml
</IfModule>
